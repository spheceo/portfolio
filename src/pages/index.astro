---
import Layout from "../layout.astro";
import clsx from "clsx"
import { IoIosArrowForward } from "react-icons/io";
import { MdArrowOutward } from "react-icons/md";

const links = [
    {
		name: "discord",
		href: "/discord",
		analyticsName: "discord_link"
	},
	{
		name: "github",
		href: "https://github.com/spheceo",
		analyticsName: "github_link"
	},
	{
		name: "twitter",
		href: "https://x.com/spheceo",
		analyticsName: "twitter_link"
	}
]

---

<Layout class="flex flex-col justify-center items-center">
    <!-- Cover image -->
    <div class="h-dvh w-dvw absolute -z-10 overflow-hidden motion-delay-500 motion-preset-fade motion-duration-5000">
        <div class="absolute bottom-0 z-10 bg-linear-to-t from-background/90 to-transparent w-full h-1/7"/>
        <img src="/cover/01.png" class="absolute object-cover opacity-100 top-100"/>
    </div>
    
	<div class="max-w-xs w-full mx-auto motion-delay-500 motion-blur-in-xl motion-duration-500">
		<!-- Header -->
		<header class="mb-16 motion-delay-500 motion-opacity-in-0 motion-translate-y-in-150">
			<h1 class="text-2xl">sphe</h1>
			<p class="text-muted mt-1 text-sm">creating things i wish existed.</p>
		</header>

		<!-- Links -->
		<nav class="flex flex-col w-full gap-5">
			{links.map((l, i) => (
				<div style={`--motion-delay: ${700 + i * 200}ms`} class="group w-full cursor-pointer motion-opacity-in-0 motion-translate-y-in-150">
					<div class="flex items-center justify-between">
						<a href={l.href} data-analytics-name={l.analyticsName} class="text-subtle block my-1 transition-all duration-400 group-hover:text-foreground" target={clsx(l.href.startsWith("http") ? "_blank" : undefined)}>
							{l.name}
						</a>
						<span class="transition-all duration-400 opacity-0 group-hover:opacity-100 text-muted">
							{l.href.startsWith("http") ? <MdArrowOutward size={14}/> : <IoIosArrowForward size={14}/>}
						</span>
					</div>
					<div class="bg-foreground h-px transition-all duration-400 ease-in-out origin-left scale-x-0 group-hover:scale-x-100" />
				</div>
			))}
		</nav>
	</div>
</Layout>
